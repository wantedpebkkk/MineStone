# Required
DISCORD_TOKEN=your_discord_bot_token_here

# Optional – enables Spotify search (recommended)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional – change the command prefix (default: !)
PREFIX=!

# Optional – set to true only when hosting on Replit/UptimeRobot (starts Flask keep-alive server)
# Leave false (or unset) for self-hosting on a PC, VPS, or Docker
KEEP_ALIVE=false

# Optional – Voice channel ID to auto-join on startup with 24/7 mode enabled.
# Right-click any voice channel in Discord → "Copy Channel ID" (requires Developer Mode).
# When set, the bot joins this channel automatically every time it starts and stays forever.
AUTO_JOIN_CHANNEL_ID=
